# === Data pipeline config ===
# BE Data owns this Python/FastAPI service. BE Agent consumes it when available.
BE_DATA_SERVICE_URL=http://localhost:8000
# Merchant Moe is the Mantle-first Scout source. Leave empty until BE Data/indexing confirms the endpoint.
MERCHANT_MOE_SUBGRAPH_URL=
# coingecko: optional pro key; blank uses public rate-limited API
COINGECKO_API_KEY=
# storage provider for report bodies: stub | ipfs
STORAGE_PROVIDER=ipfs
# IPFS (web3.storage / pinata jwt) - only used when STORAGE_PROVIDER=ipfs
IPFS_TOKEN=
IPFS_API_KEY=
IPFS_API_SECRET=
