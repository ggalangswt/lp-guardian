# === Databases ===
DATABASE_URL=postgresql://lpguardian:lpguardian_dev@localhost:5434/lpguardian
REDIS_URL=redis://localhost:6380

# === Uniswap ===
# The Graph QUERY api key (not a deploy key)
THE_GRAPH_KEY=
UNISWAP_TRADING_API_KEY=
# NOTE: this id is the Ethereum MAINNET Uniswap V3 subgraph (no Arbitrum data).
# No confirmed Arbitrum V3 decentralized subgraph found. V3 swap replay falls
# back to RPC getLogs (indexer/swapEvents.ts), which works. Replace with a real
# Arbitrum V3 subgraph id if one becomes available.
UNISWAP_V3_SUBGRAPH_ID=5zvR82QoaXYFyDEKLZ9t6v9adgnptxYpKpSbxtgVENFV
# NOTE: this default is MAINNET; set a working Arbitrum V4 id locally if needed.
UNISWAP_V4_SUBGRAPH_ID=DiYPVdygkfjDWhbxGSqAQxwBKmfKnkWQojqeM2rkLb3G

# === Robinhood Chain (Arbitrum Orbit) ===
# Use a private provider endpoint locally; do not commit real API keys here.
ROBINHOOD_RPC=https://robinhood-testnet.g.alchemy.com/v2/<YOUR_API_KEY>
ROBINHOOD_CHAIN_ID=46630
ROBINHOOD_NFPM_ADDRESS=
ROBINHOOD_V3_FACTORY_ADDRESS=
ROBINHOOD_SCAN_FROM_BLOCK=0
# Keep this at 10 for free-tier RPCs that cap eth_getLogs ranges.
ROBINHOOD_SCAN_CHUNK_SIZE=10
# Refuse wallet scans that would require too many getLogs chunks.
ROBINHOOD_MAX_SCAN_RANGES=1000
ROBINHOOD_CANONICAL_WALLET_ADDRESS=
ROBINHOOD_CANONICAL_TOKEN_ID=

# === Mantle Turing Test ===
# robinhood | mantle. Keep robinhood for legacy LP scans; use mantle for Turing registry writes.
LPGUARDIAN_CHAIN_MODE=mantle
# Mainnet defaults. Testnet: MANTLE_RPC=https://rpc.sepolia.mantle.xyz and MANTLE_CHAIN_ID=5003.
MANTLE_RPC=https://rpc.mantle.xyz
MANTLE_CHAIN_ID=5000
# LPGuardianTuringRegistry Mantle Sepolia deploy tx:
# 0x929474928d21c3fc69ab2a565e4894213edf72befe3bebac3f828e9dc8c6f47e
# Explorer: https://explorer.sepolia.mantle.xyz/tx/0x929474928d21c3fc69ab2a565e4894213edf72befe3bebac3f828e9dc8c6f47e
MANTLE_TURING_REGISTRY=0x3338C6C85399e9E9d28233a186643a5383C6c736
LPGUARDIAN_TURING_REGISTRY=0x3338C6C85399e9E9d28233a186643a5383C6c736
LPGUARDIAN_TURING_AGENT_ID=
# Frozen interface placeholders; fill after SC deployment.
LPGUARDIAN_PERMIT2_BUNDLER=
LPGUARDIAN_TEE_ANCHOR=

# === Ethereum ===
MAINNET_RPC=https://eth.llamarpc.com

ARBITRUM_RPC=https://arb1.arbitrum.io/rpc
