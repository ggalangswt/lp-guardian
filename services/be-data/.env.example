# BE Data service configuration. Copy to .env for local development.

# --- HTTP server ---
BE_DATA_HOST=0.0.0.0
BE_DATA_PORT=8000

# --- Auth ---
# When set, all POST endpoints (/compute/*, /tee/sign) require
# `Authorization: Bearer <token>`. Leave empty for local dev. /health stays open.
# In production set this as an encrypted secret on Phala Cloud and use the same
# value for BE_DATA_AUTH_TOKEN on the Node backend.
BE_DATA_AUTH_TOKEN=

# --- Prices: primary path ---
# The compute endpoints accept `priceHistory` directly. In production the Node
# backend fetches it (CoinGecko) and passes it in as attested inputs because the
# TEE CVM has no egress. The sources below are independent BE Data fetchers /
# cross-checks; all degrade to UNAVAILABLE provenance when unreachable.

# --- Bybit market data (POST /prices/bybit) ---
# Public klines need no API key. BYBIT_SYMBOL_MAP maps lowercased token address
# -> Bybit spot symbol so closes drop into `priceHistory`.
BYBIT_API_BASE=https://api.bybit.com
# Example: {"0xdeaddeaddeaddeaddeaddeaddeaddeaddead0000":"MNTUSDT","0xcda86a272531e8640cd7f1a92c01839911b90bb0":"ETHUSDT"}
BYBIT_SYMBOL_MAP=

# --- Chainlink price feeds (POST /prices/chainlink) — MUST-HAVE oracle fallback ---
# JSON map of SYMBOL -> AggregatorV3 feed address on Mantle. Verify addresses at
# https://docs.chain.link/data-feeds/price-feeds/addresses?network=mantle
# Example: {"ETH/USD":"0x...","MNT/USD":"0x..."}
CHAINLINK_FEEDS=

# --- Mantle RPC + NFPM (on-chain position reader + Chainlink reads) ---
# MANTLE_RPC_URL powers GET /positions/onchain/{wallet} and the Chainlink reads.
# NFPM_ADDRESS is a Uniswap-V3-style NonfungiblePositionManager. Use Agni's V3
# NFPM (Merchant Moe is Liquidity Book / bin-based and has NO V3 NFPM).
MANTLE_RPC_URL=https://rpc.mantle.xyz
NFPM_ADDRESS=

# --- Protocol subgraphs (GET /positions/{protocol}/{wallet}) ---
# Merchant Moe is the Mantle-first must-have Scout source; Agni/Fluxion are
# nice-to-have. Leave empty until the endpoint is confirmed (degrades to
# UNAVAILABLE). Agni positions can also be read on-chain via /positions/onchain.
MERCHANT_MOE_SUBGRAPH_URL=
AGNI_SUBGRAPH_URL=
FLUXION_SUBGRAPH_URL=

# --- TEE signing ---
# auto = Phala dstack socket -> developer-key.
# Force with: phala | developer-key
TEE_PROVIDER=auto
# Only used by the developer-key fallback. NOT a hardware attestation.
DEVELOPER_SIGNING_KEY=lp-guardian-be-data-dev-key-do-not-use-in-prod

# --- Portfolio math tuning ---
# Liquidity below this is treated as dust in the CONSOLIDATE_DUST scenario.
BE_DATA_DUST_THRESHOLD_LIQUIDITY=1e15
BE_DATA_MONTE_CARLO_PATHS=1000

# --- Hardening (public CVM endpoints; 0 disables a check) ---
# Reject POST bodies larger than this many bytes (413).
BE_DATA_MAX_BODY_BYTES=1000000
# Per-IP fixed-window POST rate limit per minute (429 when exceeded).
BE_DATA_RATE_LIMIT_PER_MIN=120
